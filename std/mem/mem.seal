c :: @c_import {
    include "stdlib.h"
}

Malloc :: extern("malloc") task(size uint) rawptr
CFree  :: extern("free") task(ptr rawptr)

Allocator :: interface {
    Alloc :: task(a *$T, size uint) rawptr
    Free  :: task(a *$T, ptr rawptr)
}

CAllocator :: struct {}

Alloc :: task(a *CAllocator, size uint) rawptr {
    return Malloc(size)
}

Free :: task(a *CAllocator, ptr rawptr) {
    CFree(ptr)
}

CAllocator :: impl {
    Allocator,
}
