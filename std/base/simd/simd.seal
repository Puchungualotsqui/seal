Error :: enum {
    None
    InvalidArgument
}

Backend :: enum {
    Scalar
    SIMDe
}

ErrorIsNone :: pure task(
    error Error,
) bool {
    return error == .None
}

ErrorString :: pure task(
    error Error,
) string {
    if error == .None {
        return "no error"
    }

    return "invalid SIMD argument"
}

CurrentBackend :: task() Backend {
    if simdNative.Backend() == 0 {
        return .Scalar
    }

    return .SIMDe
}

BackendString :: pure task(
    backend Backend,
) string {
    if backend == .Scalar {
        return "scalar"
    }

    return "SIMDe"
}

/*
A zero-length operation accepts nil pointers because no memory is read
or written.
*/
_ValidSource :: pure task<
    T type,
>(
    source *T,
    length uint,
) bool {
    return length == 0 ||
        source != nil
}

_ValidDestinationSource :: pure task<
    T type,
>(
    destination *T,
    source *T,
    length uint,
) bool {
    return length == 0 ||
        (
            destination != nil &&
            source != nil
        )
}

_ValidDestinationBinary :: pure task<
    T type,
>(
    destination *T,
    left *T,
    right *T,
    length uint,
) bool {
    return length == 0 ||
        (
            destination != nil &&
            left != nil &&
            right != nil
        )
}

/*
f32 operations.

destination may be exactly left or right. Partially overlapping ranges
are not supported.
*/

AddF32 :: task(
    destination *f32,
    left *f32,
    right *f32,
    length uint,
) Error {
    if !_ValidDestinationBinary<f32>(
        destination,
        left,
        right,
        length,
    ) {
        return .InvalidArgument
    }

    if length > 0 {
        simdNative.AddF32(
            destination,
            left,
            right,
            length,
        )
    }

    return .None
}

SubF32 :: task(
    destination *f32,
    left *f32,
    right *f32,
    length uint,
) Error {
    if !_ValidDestinationBinary<f32>(
        destination,
        left,
        right,
        length,
    ) {
        return .InvalidArgument
    }

    if length > 0 {
        simdNative.SubF32(
            destination,
            left,
            right,
            length,
        )
    }

    return .None
}

MulF32 :: task(
    destination *f32,
    left *f32,
    right *f32,
    length uint,
