    return .None
}

ScaleF32 :: task(
    destination *f32,
    source *f32,
    scalar f32,
    length uint,
) Error {
    if !_ValidDestinationSource<f32>(
        destination,
        source,
        length,
    ) {
        return .InvalidArgument
    }

    if length > 0 {
        simdNative.ScaleF32(
            destination,
            source,
            scalar,
            length,
        )
    }

    return .None
}

SumF32 :: task(
    source *f32,
    length uint,
) (f32, Error) {
    if !_ValidSource<f32>(
        source,
        length,
    ) {
        return cast<f32>(0),
            .InvalidArgument
    }

    if length == 0 {
        return cast<f32>(0),
            .None
    }

    return simdNative.SumF32(
        source,
        length,
    ), .None
}

DotF32 :: task(
    left *f32,
    right *f32,
    length uint,
) (f32, Error) {
    if !_ValidDestinationSource<f32>(
        left,
        right,
        length,
    ) {
        return cast<f32>(0),
            .InvalidArgument
    }

    if length == 0 {
        return cast<f32>(0),
            .None
    }

    return simdNative.DotF32(
        left,
        right,
        length,
    ), .None
}

