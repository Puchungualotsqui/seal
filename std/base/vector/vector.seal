/*
u32 operations.

Unsigned arithmetic uses normal wrapping behavior.

The destination may be exactly the same slice as a source.
Partially overlapping slices are not supported.
*/

AddU32 :: task(
    destination lists.Slice<u32>,
    left lists.Slice<u32>,
    right lists.Slice<u32>,
) Error {
    validation :=
        _ValidateBinary<u32>(
            &destination,
            &left,
            &right,
        )

    if !ErrorIsNone(
        validation,
    ) {
        return validation
    }

    length :=
        lists.SliceLength<u32>(
            &destination,
        )

    simdError :=
        simd.AddU32(
            _DataU32(
                &destination,
            ),
            _DataU32(
                &left,
            ),
            _DataU32(
                &right,
            ),
            length,
        )

    return _FromSIMDSuccess(
        simd.ErrorIsNone(
            simdError,
        ),
    )
}

