ScaleF32 :: task(
    destination lists.Slice<f32>,
    source lists.Slice<f32>,
    scalar f32,
) Error {
    validation :=
        _ValidateDestinationSource<f32>(
            &destination,
            &source,
        )

    if !ErrorIsNone(
        validation,
    ) {
        return validation
    }

    length :=
        lists.SliceLength<f32>(
            &destination,
        )

    simdError :=
        simd.ScaleF32(
            _DataF32(
                &destination,
            ),
            _DataF32(
                &source,
            ),
            scalar,
            length,
        )

    return _FromSIMDSuccess(
        simd.ErrorIsNone(
            simdError,
        ),
    )
}

SumF32 :: task(
    source lists.Slice<f32>,
) (f32, Error) {
    validation :=
        _ValidateSource<f32>(
            &source,
        )

    if !ErrorIsNone(
        validation,
    ) {
        return cast<f32>(0),
            validation
    }

    length :=
        lists.SliceLength<f32>(
            &source,
        )

    result, simdError :=
        simd.SumF32(
            _DataF32(
                &source,
            ),
            length,
        )

    return result,
        _FromSIMDSuccess(
            simd.ErrorIsNone(
                simdError,
            ),
        )
}

DotF32 :: task(
    left lists.Slice<f32>,
    right lists.Slice<f32>,
) (f32, Error) {
    validation :=
        _ValidatePair<f32>(
            &left,
            &right,
        )

    if !ErrorIsNone(
        validation,
    ) {
        return cast<f32>(0),
            validation
    }

    length :=
        lists.SliceLength<f32>(
            &left,
        )

    result, simdError :=
        simd.DotF32(
            _DataF32(
                &left,
            ),
            _DataF32(
                &right,
            ),
            length,
        )

    return result,
        _FromSIMDSuccess(
            simd.ErrorIsNone(
                simdError,
            ),
        )
}

