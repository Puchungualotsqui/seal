Error :: enum {
    None
    InvalidArgument
    LengthMismatch
}

ErrorIsNone :: pure task(
    error Error,
) bool {
    return error == .None
}

ErrorString :: pure task(
    error Error,
) string {
    if error == .None {
        return "no error"
    }

    if error ==
        .InvalidArgument {
        return "invalid vector argument"
    }

    return "vector lengths do not match"
}

/*
_FromSIMDSuccess deliberately accepts bool instead of simd.Error.

This prevents the private SIMD error type from leaking into generated
declarations in packages that depend on vector.
*/
_FromSIMDSuccess :: pure task(
    succeeded bool,
) Error {
    if succeeded {
        return .None
    }

    return .InvalidArgument
}

/*
An empty slice may contain a nil data pointer.
*/
_SliceIsValid :: pure task<
    T type,
>(
    values *lists.Slice<T>,
) bool {
    if values == nil {
        return false
    }

    length :=
        lists.SliceLength<T>(
            values,
        )

    return length == 0 ||
        lists.SliceData<T>(
            values,
        ) != nil
}

_ValidateSource :: pure task<
    T type,
>(
    source *lists.Slice<T>,
) Error {
    if !_SliceIsValid<T>(
        source,
    ) {
        return .InvalidArgument
    }

    return .None
}

_ValidateDestinationSource :: pure task<
    T type,
>(
    destination *lists.Slice<T>,
    source *lists.Slice<T>,
) Error {
    if !_SliceIsValid<T>(
        destination,
    ) ||
        !_SliceIsValid<T>(
            source,
        ) {
        return .InvalidArgument
    }

    destinationLength :=
        lists.SliceLength<T>(
            destination,
        )

    sourceLength :=
        lists.SliceLength<T>(
            source,
        )

    if destinationLength !=
        sourceLength {
        return .LengthMismatch
    }

    return .None
}

_ValidateBinary :: pure task<
    T type,
>(
    destination *lists.Slice<T>,
    left *lists.Slice<T>,
    right *lists.Slice<T>,
) Error {
    if !_SliceIsValid<T>(
        destination,
    ) ||
        !_SliceIsValid<T>(
            left,
        ) ||
        !_SliceIsValid<T>(
            right,
        ) {
        return .InvalidArgument
    }

    destinationLength :=
        lists.SliceLength<T>(
            destination,
        )

    leftLength :=
        lists.SliceLength<T>(
            left,
        )

    rightLength :=
        lists.SliceLength<T>(
            right,
        )

    if destinationLength !=
        leftLength ||
        leftLength !=
            rightLength {
        return .LengthMismatch
    }

    return .None
}

_ValidatePair :: pure task<
    T type,
>(
    left *lists.Slice<T>,
    right *lists.Slice<T>,
) Error {
    if !_SliceIsValid<T>(
        left,
    ) ||
        !_SliceIsValid<T>(
            right,
        ) {
        return .InvalidArgument
    }

    leftLength :=
        lists.SliceLength<T>(
            left,
        )

    rightLength :=
        lists.SliceLength<T>(
            right,
        )

    if leftLength !=
        rightLength {
        return .LengthMismatch
    }

    return .None
}

/*
Typed borrowed data pointers.
*/

_DataF32 :: pure task(
    values *lists.Slice<f32>,
) *f32 {
    return cast<*f32>(
        lists.SliceData<f32>(
            values,
        ),
    )
}

_DataF64 :: pure task(
    values *lists.Slice<f64>,
) *f64 {
    return cast<*f64>(
        lists.SliceData<f64>(
            values,
        ),
    )
}

_DataU32 :: pure task(
    values *lists.Slice<u32>,
) *u32 {
    return cast<*u32>(
        lists.SliceData<u32>(
            values,
        ),
    )
}

/*
f32 operations.

The destination may be exactly the same slice as a source.
Partially overlapping slices are not supported.
*/

AddF32 :: task(
    destination lists.Slice<f32>,
    left lists.Slice<f32>,
    right lists.Slice<f32>,
) Error {
    validation :=
        _ValidateBinary<f32>(
            &destination,
            &left,
            &right,
        )

    if !ErrorIsNone(
        validation,
    ) {
        return validation
    }

    length :=
        lists.SliceLength<f32>(
            &destination,
        )

    simdError :=
        simd.AddF32(
            _DataF32(
                &destination,
            ),
            _DataF32(
                &left,
            ),
            _DataF32(
                &right,
            ),
            length,
        )

    return _FromSIMDSuccess(
        simd.ErrorIsNone(
            simdError,
        ),
    )
}

