/*
ThreadResult is the physical result type used by native thread entry
tasks.
*/
ThreadResult :: @foreign_type(
    uintptr_t
)

thread_success :: @foreign_value(
    ThreadResult,
    0
)

/*
ThreadEntryABI describes the native callback signature.

Task addresses are consumed only by the native thread bridge.
*/
ThreadEntryABI :: @foreign_task(
    declaration uintptr_t {name}(void *{arg0_name}),
    address ((void *){name}),
)

/*
Thread operations.
*/

Start :: extern("seal_thread_start") task(
    entry rawptr,
    context rawptr,
) rawptr

Join :: extern("seal_thread_join") task(
    handle rawptr,
) bool

/*
JoinFor returns:

    1  joined
    0  timeout
   -1  native failure
*/
JoinFor :: extern("seal_thread_join_for") task(
    handle rawptr,
    milliseconds uint,
) int

Detach :: extern("seal_thread_detach") task(
    handle rawptr,
) bool

AllocateContext :: extern(
    "seal_thread_allocate_context"
) task(
    byteSize uint,
) rawptr

FreeContext :: extern(
    "seal_thread_free_context"
) task(
    context rawptr,
)

Yield :: extern(
    "seal_thread_yield"
) task()

Sleep :: extern(
    "seal_thread_sleep"
) task(
    milliseconds uint,
)

HardwareThreadCount :: extern(
    "seal_thread_hardware_thread_count"
) task() uint

CurrentThreadID :: extern(
    "seal_thread_current_id"
) task() uint

/*
Mutex operations.
*/

CreateMutex :: extern(
    "seal_mutex_create"
) task() rawptr

DestroyMutex :: extern(
    "seal_mutex_destroy"
) task(
    handle rawptr,
) bool

LockMutex :: extern(
    "seal_mutex_lock"
) task(
    handle rawptr,
) bool

/*
TryLockMutex returns:

    1  acquired
    0  unavailable
   -1  native failure
*/
TryLockMutex :: extern(
    "seal_mutex_try_lock"
) task(
    handle rawptr,
) int

UnlockMutex :: extern(
    "seal_mutex_unlock"
) task(
    handle rawptr,
) bool

/*
Condition-variable operations.
*/

CreateCondition :: extern(
    "seal_condition_create"
) task() rawptr

DestroyCondition :: extern(
    "seal_condition_destroy"
) task(
    handle rawptr,
) bool

WaitCondition :: extern(
    "seal_condition_wait"
) task(
    condition rawptr,
    mutex rawptr,
) bool

/*
WaitConditionFor returns:

    1  signaled
    0  timeout
   -1  native failure
*/
WaitConditionFor :: extern(
    "seal_condition_wait_for"
) task(
    condition rawptr,
    mutex rawptr,
    milliseconds uint,
) int

SignalCondition :: extern(
    "seal_condition_signal"
) task(
    condition rawptr,
) bool

BroadcastCondition :: extern(
    "seal_condition_broadcast"
) task(
    condition rawptr,
) bool

/*
Once operations.
*/

CreateOnce :: extern(
    "seal_once_create"
) task() rawptr

DestroyOnce :: extern(
    "seal_once_destroy"
) task(
    handle rawptr,
) bool

/*
BeginOnce returns:

    1  this caller must initialize
    0  initialization is complete
   -1  native failure
*/
BeginOnce :: extern(
    "seal_once_begin"
) task(
    handle rawptr,
) int

CompleteOnce :: extern(
    "seal_once_complete"
) task(
    handle rawptr,
) bool

