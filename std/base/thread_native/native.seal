/*
Atomic operations.

The native representation stores uintptr_t bits. Signed integer and
boolean wrappers are implemented in the atomic Seal package.
*/

CreateAtomic :: extern(
    "seal_atomic_create"
) task(
    initialValue uint,
) rawptr

DestroyAtomic :: extern(
    "seal_atomic_destroy"
) task(
    handle rawptr,
) bool

LoadAtomic :: extern(
    "seal_atomic_load"
) task(
    handle rawptr,
) uint

StoreAtomic :: extern(
    "seal_atomic_store"
) task(
    handle rawptr,
    value uint,
) bool

ExchangeAtomic :: extern(
    "seal_atomic_exchange"
) task(
    handle rawptr,
    value uint,
) uint

CompareExchangeAtomic :: extern(
    "seal_atomic_compare_exchange"
) task(
    handle rawptr,
    expected uint,
    desired uint,
) bool

FetchAddAtomic :: extern(
    "seal_atomic_fetch_add"
) task(
    handle rawptr,
    amount uint,
) uint

FetchSubAtomic :: extern(
    "seal_atomic_fetch_sub"
) task(
    handle rawptr,
    amount uint,
) uint

FetchAndAtomic :: extern(
    "seal_atomic_fetch_and"
) task(
    handle rawptr,
    value uint,
) uint

FetchOrAtomic :: extern(
    "seal_atomic_fetch_or"
) task(
    handle rawptr,
    value uint,
) uint

FetchXorAtomic :: extern(
    "seal_atomic_fetch_xor"
) task(
    handle rawptr,
    value uint,
) uint
