Error :: enum {
    None
    AllocationFailed
    InvalidState
    DestroyFailed
    NativeFailure
}

AtomicInt :: struct {
    Handle rawptr
}

AtomicUint :: struct {
    Handle rawptr
}

AtomicBool :: struct {
    Handle rawptr
}

ErrorIsNone :: pure task(
    error Error,
) bool {
    return error == .None
}

TryNewInt :: task(
    initialValue int,
) (AtomicInt, Error) {
    handle :=
        threadNative.CreateAtomic(
            cast<uint>(
                initialValue,
            ),
        )

    if handle == nil {
        return AtomicInt{
            Handle = nil,
        }, .AllocationFailed
    }

    return AtomicInt{
        Handle = handle,
    }, .None
}

NewInt :: task(
    initialValue int,
) AtomicInt {
    value, error :=
        TryNewInt(initialValue)

    if !ErrorIsNone(error) {
        panic(
            "atomic.NewInt: allocation failed",
        )
    }

    return value
}

IntIsValid :: pure task(
    value *AtomicInt,
) bool {
    return value != nil &&
        value.Handle != nil
}

IntLoad :: task(
    value *AtomicInt,
) int {
    if !IntIsValid(value) {
        panic(
            "atomic.IntLoad: invalid atomic",
        )
    }

    return cast<int>(
        threadNative.LoadAtomic(
            value.Handle,
        ),
    )
}

IntStore :: task(
    value *AtomicInt,
    next int,
) Error {
    if !IntIsValid(value) {
        return .InvalidState
    }

    if !threadNative.StoreAtomic(
        value.Handle,
        cast<uint>(next),
    ) {
        return .NativeFailure
    }

    return .None
}

IntExchange :: task(
    value *AtomicInt,
    next int,
) int {
    if !IntIsValid(value) {
        panic(
            "atomic.IntExchange: invalid atomic",
        )
    }

    return cast<int>(
        threadNative.ExchangeAtomic(
            value.Handle,
            cast<uint>(next),
        ),
    )
}

IntCompareExchange :: task(
    value *AtomicInt,
    expected int,
    desired int,
) bool {
    if !IntIsValid(value) {
        return false
    }

    return
        threadNative.CompareExchangeAtomic(
            value.Handle,
            cast<uint>(expected),
            cast<uint>(desired),
        )
}

IntFetchAdd :: task(
    value *AtomicInt,
    amount int,
) int {
    if !IntIsValid(value) {
        panic(
            "atomic.IntFetchAdd: invalid atomic",
        )
    }

    return cast<int>(
        threadNative.FetchAddAtomic(
            value.Handle,
            cast<uint>(amount),
        ),
    )
}

IntFetchSub :: task(
    value *AtomicInt,
    amount int,
) int {
    if !IntIsValid(value) {
        panic(
            "atomic.IntFetchSub: invalid atomic",
        )
    }

    return cast<int>(
        threadNative.FetchSubAtomic(
            value.Handle,
            cast<uint>(amount),
        ),
    )
}

DestroyInt :: task(
    value *AtomicInt,
) Error {
    if !IntIsValid(value) {
        return .InvalidState
    }

    if !threadNative.DestroyAtomic(
        value.Handle,
    ) {
        return .DestroyFailed
    }

    value.Handle = nil

    return .None
}

