/*
Boolean atomic.
*/

TryNewBool :: task(
    initialValue bool,
) (AtomicBool, Error) {
    bits: uint = 0

    if initialValue {
        bits = 1
    }

    handle :=
        threadNative.CreateAtomic(
            bits,
        )

    if handle == nil {
        return AtomicBool{
            Handle = nil,
        }, .AllocationFailed
    }

    return AtomicBool{
        Handle = handle,
    }, .None
}

NewBool :: task(
    initialValue bool,
) AtomicBool {
    value, error :=
        TryNewBool(initialValue)

    if !ErrorIsNone(error) {
        panic(
            "atomic.NewBool: allocation failed",
        )
    }

    return value
}

BoolIsValid :: pure task(
    value *AtomicBool,
) bool {
    return value != nil &&
        value.Handle != nil
}

BoolLoad :: task(
    value *AtomicBool,
) bool {
    if !BoolIsValid(value) {
        panic(
            "atomic.BoolLoad: invalid atomic",
        )
    }

    return
        threadNative.LoadAtomic(
            value.Handle,
        ) != 0
}

BoolStore :: task(
    value *AtomicBool,
    next bool,
) Error {
    if !BoolIsValid(value) {
        return .InvalidState
    }

    bits: uint = 0

    if next {
        bits = 1
    }

    if !threadNative.StoreAtomic(
        value.Handle,
        bits,
    ) {
        return .NativeFailure
    }

    return .None
}

BoolExchange :: task(
    value *AtomicBool,
    next bool,
) bool {
    if !BoolIsValid(value) {
        panic(
            "atomic.BoolExchange: invalid atomic",
        )
    }

    bits: uint = 0

    if next {
        bits = 1
    }

    return
        threadNative.ExchangeAtomic(
            value.Handle,
            bits,
        ) != 0
}

BoolCompareExchange :: task(
    value *AtomicBool,
    expected bool,
    desired bool,
) bool {
    if !BoolIsValid(value) {
        return false
    }

    expectedBits: uint = 0
    desiredBits: uint = 0

    if expected {
        expectedBits = 1
    }

    if desired {
        desiredBits = 1
    }

    return
        threadNative.CompareExchangeAtomic(
            value.Handle,
            expectedBits,
            desiredBits,
        )
}

DestroyBool :: task(
    value *AtomicBool,
) Error {
    if !BoolIsValid(value) {
        return .InvalidState
    }

    if !threadNative.DestroyAtomic(
        value.Handle,
    ) {
        return .DestroyFailed
    }

    value.Handle = nil

    return .None
}
