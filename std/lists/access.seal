/*
Slice access.
*/

SliceGet :: pure task <T type>(
    values *Slice<T>,
    index int,
) T, bool {
    normalized, valid := _TryNormalizeIndex(
        index,
        values._length,
    )

    if !valid {
        empty: T

        return empty, false
    }

    return _ReadSlot<T>(
        values._data,
        normalized,
    ), true
}

SliceGetUnsafe :: pure task <T type>(
    values *Slice<T>,
    index uint,
) T {
    return _ReadSlot<T>(
        values._data,
        index,
    )
}

SliceTrySet :: task <T type>(
    values *Slice<T>,
    index int,
    value T,
) bool {
    normalized, valid := _TryNormalizeIndex(
        index,
        values._length,
    )

    if !valid {
        return false
    }

    _WriteSlot<T>(
        values._data,
        normalized,
        value,
    )

    return true
}

SliceSetUnsafe :: task <T type>(
    values *Slice<T>,
    index uint,
    value T,
) {
    _WriteSlot<T>(
        values._data,
        index,
        value,
    )
}

