/*
Deque access.
*/

DequeGet :: pure task <T type>(
    deque *Deque<T>,
    index int,
) T, bool {
    logicalIndex, valid := _TryNormalizeIndex(
        index,
        deque._length,
    )

    if !valid {
        empty: T

        return empty, false
    }

    physicalIndex := _DequePhysicalIndex<T>(
        deque,
        logicalIndex,
    )

    return _ReadSlot<T>(
        deque._data,
        physicalIndex,
    ), true
}

DequeGetUnsafe :: pure task <T type>(
    deque *Deque<T>,
    index uint,
) T {
    physicalIndex := _DequePhysicalIndex<T>(
        deque,
        index,
    )

    return _ReadSlot<T>(
        deque._data,
        physicalIndex,
    )
}

DequeTrySet :: task <T type>(
    deque *Deque<T>,
    index int,
    value T,
) bool {
    logicalIndex, valid := _TryNormalizeIndex(
        index,
        deque._length,
    )

    if !valid {
        return false
    }

    physicalIndex := _DequePhysicalIndex<T>(
        deque,
        logicalIndex,
    )

    _WriteSlot<T>(
        deque._data,
        physicalIndex,
        value,
    )

    return true
}

DequeSetUnsafe :: task <T type>(
    deque *Deque<T>,
    index uint,
    value T,
) {
    physicalIndex := _DequePhysicalIndex<T>(
        deque,
        index,
    )

    _WriteSlot<T>(
        deque._data,
        physicalIndex,
        value,
    )
}

/*
Stack access.
*/

StackTryPeek :: pure task <T type>(
    stack *Stack<T>,
) T, bool {
    if stack._values._length == 0 {
        empty: T

        return empty, false
    }

    return _ReadSlot<T>(
        stack._values._data,
        stack._values._length - 1,
    ), true
}

StackPeekUnsafe :: pure task <T type>(
    stack *Stack<T>,
) T {
    return _ReadSlot<T>(
        stack._values._data,
        stack._values._length - 1,
    )
}

/*
Deque end access.
*/

DequeTryFront :: pure task <T type>(
    deque *Deque<T>,
) T, bool {
    if deque._length == 0 {
        empty: T

        return empty, false
    }

    return _ReadSlot<T>(
        deque._data,
        deque._head,
    ), true
}

DequeFrontUnsafe :: pure task <T type>(
    deque *Deque<T>,
) T {
    return _ReadSlot<T>(
        deque._data,
        deque._head,
    )
}

DequeTryBack :: pure task <T type>(
    deque *Deque<T>,
) T, bool {
    if deque._length == 0 {
        empty: T

        return empty, false
    }

    physicalIndex := _DequePhysicalIndex<T>(
        deque,
        deque._length - 1,
    )

    return _ReadSlot<T>(
        deque._data,
        physicalIndex,
    ), true
}

DequeBackUnsafe :: pure task <T type>(
    deque *Deque<T>,
) T {
    physicalIndex := _DequePhysicalIndex<T>(
        deque,
        deque._length - 1,
    )

    return _ReadSlot<T>(
        deque._data,
        physicalIndex,
    )
}

/*
Queue front access.
*/

QueueTryFront :: pure task <T type>(
    queue *Queue<T>,
) T, bool {
    return DequeTryFront<T>(
        &queue._deque,
    )
}

QueueFrontUnsafe :: pure task <T type>(
    queue *Queue<T>,
) T {
    return DequeFrontUnsafe<T>(
        &queue._deque,
    )
}
