/*
Compile-time-length heap arrays.
*/

StaticArrayGet :: pure task <
    T type,
    N int[N >= 0],
>(
    values *StaticArray<T, N>,
    index int,
) T, bool {
    normalized, valid := _TryNormalizeIndex(
        index,
        cast<uint>(N),
    )

    if !valid {
        empty: T

        return empty, false
    }

    return _ReadSlot<T>(
        values._data,
        normalized,
    ), true
}

StaticArrayGetUnsafe :: pure task <
    T type,
    N int[N >= 0],
>(
    values *StaticArray<T, N>,
    index uint,
) T {
    return _ReadSlot<T>(
        values._data,
        index,
    )
}

StaticArrayTrySet :: task <
    T type,
    N int[N >= 0],
>(
    values *StaticArray<T, N>,
    index int,
    value T,
) bool {
    normalized, valid := _TryNormalizeIndex(
        index,
        cast<uint>(N),
    )

    if !valid {
        return false
    }

    _WriteSlot<T>(
        values._data,
        normalized,
        value,
    )

    return true
}

StaticArraySetUnsafe :: task <
    T type,
    N int[N >= 0],
>(
    values *StaticArray<T, N>,
    index uint,
    value T,
) {
    _WriteSlot<T>(
        values._data,
        index,
        value,
    )
}

