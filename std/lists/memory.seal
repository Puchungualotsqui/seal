/*
_ByteCount calculates storage required for count elements.

It panics if the multiplication overflows.
*/
_ByteCount :: pure task <T type>(
    count uint,
) uint {
    elementSize := size(T)

    if count == 0 ||
        elementSize == 0 {
        return 0
    }

    byteCount := count * elementSize

    if byteCount / count != elementSize {
        panic("lists: allocation size overflow")
    }

    return byteCount
}

/*
_GrowCapacity applies:

    max(requiredCapacity, oldCapacity * 2)
*/
_GrowCapacity :: pure task(
    oldCapacity uint,
    requiredCapacity uint,
) uint {
    if requiredCapacity <= oldCapacity {
        return oldCapacity
    }

    if oldCapacity == 0 {
        return requiredCapacity
    }

    doubled := oldCapacity * 2

    if doubled / 2 != oldCapacity {
        return requiredCapacity
    }

    if doubled < requiredCapacity {
        return requiredCapacity
    }

    return doubled
}

/*
_NormalizeIndex normalizes an existing-element index.

Negative indexes are interpreted relative to length.
*/
_NormalizeIndex :: pure task(
    index int,
    length uint,
) uint {
    normalized := index
    signedLength := cast<int>(length)

    if normalized < 0 {
        normalized += signedLength
    }

    if normalized < 0 ||
        normalized >= signedLength {
        panic("lists: index out of bounds")
    }

    return cast<uint>(normalized)
}

/*
_TryNormalizeIndex returns false instead of panicking.
*/
_TryNormalizeIndex :: pure task(
    index int,
    length uint,
) uint, bool {
    normalized := index
    signedLength := cast<int>(length)

    if normalized < 0 {
        normalized += signedLength
    }

    if normalized < 0 ||
        normalized >= signedLength {
        return 0, false
    }

    return cast<uint>(normalized), true
}

/*
_NormalizeInsertIndex normalizes an insertion boundary.

The resulting index may equal length.
*/
_NormalizeInsertIndex :: pure task(
    index int,
    length uint,
) uint {
    normalized := index
    signedLength := cast<int>(length)

    if normalized < 0 {
        normalized += signedLength
    }

    if normalized < 0 ||
        normalized > signedLength {
        panic("lists: insertion index out of bounds")
    }

    return cast<uint>(normalized)
}

/*
_ElementPointer returns a pointer to one element.

No bounds checking is performed.
*/
_ElementPointer :: pure task <T type>(
    data rawptr,
    index uint,
) *T {
    byteOffset := index * size(T)

    return cast<*T>(
        &data[cast<int>(byteOffset)]
    )
}

/*
_Allocate allocates storage for count elements.

A zero count produces nil storage.
*/
_Allocate :: task <T type>(
    allocator mem.Allocator,
    count uint,
) rawptr {
    if count == 0 {
        return nil
    }

    byteCount := _ByteCount<T>(count)

    data := mem.AllocWith(
        allocator,
        byteCount,
    )

    if data == nil {
        panic("lists: allocation failed")
    }

    return data
}

/*
_AllocateZeroed allocates zero-filled storage.
*/
_AllocateZeroed :: task <T type>(
    allocator mem.ZeroAllocator,
    count uint,
) rawptr {
    if count == 0 {
        return nil
    }

    data := mem.AllocZeroedWith(
        allocator,
        count,
        size(T),
    )

    if data == nil {
        panic("lists: allocation failed")
    }

    return data
}

/*
_DestroyStorage releases an allocation and accepts nil.
*/
_DestroyStorage :: task(
    deallocator mem.Deallocator,
    data rawptr,
) {
    if data == nil {
        return
    }

    mem.FreeWith(
        deallocator,
        data,
    )
}
