Sum :: task(args ...int) int {
    total := 0

    for i := 0; i < len(args); i = i + 1 {
        total = total + args[i]
    }

    return total
}

CountAny :: task(args ...any) int {
    return len(args)
}

Main :: task() {
    x: any = 10

    Print(Sum(1, 2, 3))
    Print(CountAny(x, "hello", 3.14))
}
