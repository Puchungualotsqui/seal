    assert(len(staticFilled) == 3)

    assert(staticFilled[0] == 21)
    assert(staticFilled[1] == 21)
    assert(staticFilled[2] == 21)
}

TestDynamicArrayReserve :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values := lists.NewDynamicArrayEmpty<int>(
        allocator,
        deallocator,
    )

    defer lists.DestroyDynamicArray<int>(
        &values,
    )

    lists.Append<int>(&values, 1)
    lists.Append<int>(&values, 2)
    lists.Append<int>(&values, 3)

    lists.ReserveDynamicArray<int>(
        &values,
        20,
    )

    assert(len(values) == 3)

    assert(
        lists.DynamicArrayCapacity<int>(
            &values,
        ) == 20,
    )

    assert(values[0] == 1)
    assert(values[1] == 2)
    assert(values[2] == 3)

    lists.ReserveDynamicArray<int>(
        &values,
        5,
    )

    assert(
        lists.DynamicArrayCapacity<int>(
            &values,
        ) == 20,
    )
}

TestDynamicArrayInsert :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values := lists.NewDynamicArrayEmpty<int>(
        allocator,
        deallocator,
    )

    defer lists.DestroyDynamicArray<int>(
        &values,
    )

    lists.Append<int>(&values, 10)
    lists.Append<int>(&values, 30)
    lists.Append<int>(&values, 40)

    lists.Insert<int>(
        &values,
        1,
        20,
    )

    assert(len(values) == 4)

    assert(values[0] == 10)
    assert(values[1] == 20)
    assert(values[2] == 30)
    assert(values[3] == 40)

    lists.Insert<int>(
        &values,
        0,
        5,
    )

    assert(len(values) == 5)

    assert(values[0] == 5)
    assert(values[1] == 10)

    lists.Insert<int>(
        &values,
        cast<int>(len(values)),
        50,
    )

    assert(len(values) == 6)
    assert(values[-1] == 50)

    lists.Insert<int>(
        &values,
        -1,
        45,
    )

    assert(len(values) == 7)

    assert(values[5] == 45)
    assert(values[6] == 50)
}

TestDynamicArrayRemove :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values := lists.NewDynamicArrayEmpty<int>(
        allocator,
        deallocator,
    )

    defer lists.DestroyDynamicArray<int>(
        &values,
    )

    lists.Append<int>(&values, 10)
    lists.Append<int>(&values, 20)
    lists.Append<int>(&values, 30)
    lists.Append<int>(&values, 40)
    lists.Append<int>(&values, 50)

    removedMiddle := lists.Remove<int>(
        &values,
        2,
    )

    assert(removedMiddle == 30)
    assert(len(values) == 4)

    assert(values[0] == 10)
    assert(values[1] == 20)
    assert(values[2] == 40)
    assert(values[3] == 50)

    removedFirst := lists.Remove<int>(
        &values,
        0,
    )

    assert(removedFirst == 10)
    assert(len(values) == 3)
    assert(values[0] == 20)

    removedLast := lists.Remove<int>(
        &values,
        -1,
    )

    assert(removedLast == 50)
    assert(len(values) == 2)

    assert(values[0] == 20)
    assert(values[1] == 40)
}

TestDynamicArrayPop :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values := lists.NewDynamicArrayEmpty<int>(
        allocator,
        deallocator,
    )

    defer lists.DestroyDynamicArray<int>(
        &values,
    )

    emptyValue, foundEmpty := lists.Pop<int>(
        &values,
    )

    assert(!foundEmpty)
    assert(emptyValue == 0)

    lists.Append<int>(&values, 10)
    lists.Append<int>(&values, 20)
    lists.Append<int>(&values, 30)

    third, foundThird := lists.Pop<int>(
        &values,
    )

    assert(foundThird)
    assert(third == 30)
    assert(len(values) == 2)

    second, foundSecond := lists.Pop<int>(
        &values,
    )

    assert(foundSecond)
    assert(second == 20)
    assert(len(values) == 1)

    first, foundFirst := lists.Pop<int>(
        &values,
    )

    assert(foundFirst)
    assert(first == 10)
    assert(len(values) == 0)
}

