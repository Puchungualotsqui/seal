TestStaticArray :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    zeroAllocator := cast<mem.ZeroAllocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    zeroed :=
        lists.NewStaticArrayZeroed<int, 5>(
            zeroAllocator,
            deallocator,
        )

    defer lists.DestroyStaticArray<int, 5>(
        &zeroed,
    )

    assert(len(zeroed) == 5)

    assert(zeroed[0] == 0)
    assert(zeroed[4] == 0)
    assert(zeroed[-1] == 0)

    zeroed[0] = 5
    zeroed[4] = 25

    assert(zeroed[0] == 5)
    assert(zeroed[-1] == 25)

    filled :=
        lists.NewStaticArrayFilled<int, 4>(
            allocator,
            deallocator,
            9,
        )

    defer lists.DestroyStaticArray<int, 4>(
        &filled,
    )

    assert(len(filled) == 4)

    assert(filled[0] == 9)
    assert(filled[1] == 9)
    assert(filled[2] == 9)
    assert(filled[3] == 9)

    filled[1] = 18

    assert(filled[1] == 18)

    slice := lists.StaticArraySlice<int, 4>(
        &filled,
    )

    assert(len(slice) == 4)
    assert(slice[1] == 18)

    slice[2] = 27

    assert(filled[2] == 27)
}

TestDynamicArrayEmpty :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values := lists.NewDynamicArrayEmpty<int>(
        allocator,
        deallocator,
    )

    defer lists.DestroyDynamicArray<int>(
        &values,
    )

    assert(len(values) == 0)
    assert(
        lists.DynamicArrayCapacity<int>(
            &values,
        ) == 0,
    )

    lists.Append<int>(
        &values,
        10,
    )

    assert(len(values) == 1)
    assert(values[0] == 10)

    lists.Append<int>(
        &values,
        20,
    )

    lists.Append<int>(
        &values,
        30,
    )

    lists.Append<int>(
        &values,
        40,
    )

    assert(len(values) == 4)

    assert(values[0] == 10)
    assert(values[1] == 20)
    assert(values[2] == 30)
    assert(values[3] == 40)
    assert(values[-1] == 40)

    assert(
        lists.DynamicArrayCapacity<int>(
            &values,
        ) >= len(values),
    )
}

TestDynamicArrayCapacityConstructors :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    runtimeCapacity :=
        lists.DynamicArrayWithCapacity<int>(
            allocator,
            deallocator,
            8,
        )

    defer lists.DestroyDynamicArray<int>(
        &runtimeCapacity,
    )

    assert(len(runtimeCapacity) == 0)

    assert(
        lists.DynamicArrayCapacity<int>(
            &runtimeCapacity,
        ) == 8,
    )

    staticCapacity :=
        lists.DynamicArrayWithStaticCapacity<
            int,
            12,
        >(
            allocator,
            deallocator,
        )

    defer lists.DestroyDynamicArray<int>(
        &staticCapacity,
    )

    assert(len(staticCapacity) == 0)

    assert(
        lists.DynamicArrayCapacity<int>(
            &staticCapacity,
        ) == 12,
    )
}

