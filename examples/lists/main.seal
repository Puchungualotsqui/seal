        4,
        0,
    )

    defer lists.DestroyArray<int>(
        &source,
    )

    source[0] = 2
    source[1] = 4
    source[2] = 6
    source[3] = 8

    sourceSlice := lists.ArraySlice<int>(
        &source,
    )

    values := lists.DynamicArrayFromSlice<int>(
        allocator,
        deallocator,
        sourceSlice,
    )

    defer lists.DestroyDynamicArray<int>(
        &values,
    )

    assert(len(values) == 4)

    assert(values[0] == 2)
    assert(values[1] == 4)
    assert(values[2] == 6)
    assert(values[3] == 8)

    values[0] = 100

    assert(source[0] == 2)
    assert(values[0] == 100)
}

