        )

    defer lists.DestroyDynamicArray<int>(
        &runtimeFilled,
    )

    assert(len(runtimeFilled) == 5)

    assert(runtimeFilled[0] == 12)
    assert(runtimeFilled[1] == 12)
    assert(runtimeFilled[2] == 12)
    assert(runtimeFilled[3] == 12)
    assert(runtimeFilled[4] == 12)

    staticFilled :=
        lists.DynamicArrayStaticFilled<
