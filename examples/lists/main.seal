    assert(found)
    assert(value == 7)

    _, missing := lists.ArrayGet<int>(
        &values,
        3,
    )

    assert(!missing)

    changed := lists.ArrayTrySet<int>(
        &values,
        1,
        14,
    )

    assert(changed)
