TestSlice :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values := lists.ArrayFilled<int>(
        allocator,
        deallocator,
        4,
        0,
    )

    defer lists.DestroyArray<int>(
        &values,
    )

    values[0] = 10
    values[1] = 20
    values[2] = 30
    values[3] = 40

    slice := lists.ArraySlice<int>(
        &values,
    )

    assert(len(slice) == 4)

    assert(slice[0] == 10)
    assert(slice[1] == 20)
    assert(slice[-1] == 40)
    assert(slice[-2] == 30)

    slice[1] = 25

    assert(slice[1] == 25)
    assert(values[1] == 25)

    middle := lists.SliceRange<int>(
        &slice,
        1,
        3,
    )

    assert(len(middle) == 2)
    assert(middle[0] == 25)
    assert(middle[1] == 30)

    middle[0] = 26

    assert(middle[0] == 26)
    assert(values[1] == 26)

    tail := lists.SliceRange<int>(
        &slice,
        -2,
        cast<int>(len(slice)),
    )

    assert(len(tail) == 2)
    assert(tail[0] == 30)
    assert(tail[1] == 40)

    empty := lists.SliceRange<int>(
        &slice,
        2,
        2,
    )

    assert(len(empty) == 0)
}

TestRuntimeArray :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    zeroAllocator := cast<mem.ZeroAllocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values := lists.ArrayWithLength<int>(
        zeroAllocator,
        deallocator,
        5,
    )

    defer lists.DestroyArray<int>(
        &values,
    )

    assert(len(values) == 5)

    assert(values[0] == 0)
    assert(values[1] == 0)
    assert(values[-1] == 0)

    values[0] = 11
    values[2] = 33
    values[-1] = 55

    assert(values[0] == 11)
    assert(values[2] == 33)
    assert(values[4] == 55)
    assert(values[-1] == 55)

    filled := lists.ArrayFilled<int>(
        allocator,
        deallocator,
        4,
        7,
    )

    defer lists.DestroyArray<int>(
        &filled,
    )

    assert(len(filled) == 4)
    assert(filled[0] == 7)
    assert(filled[1] == 7)
    assert(filled[2] == 7)
    assert(filled[3] == 7)

    filled[2] = 100

    assert(filled[2] == 100)
}

TestArrayFromSlice :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    source := lists.ArrayFilled<int>(
        allocator,
        deallocator,
        3,
        0,
    )

    defer lists.DestroyArray<int>(
        &source,
    )

    source[0] = 10
    source[1] = 20
    source[2] = 30

    sourceSlice := lists.ArraySlice<int>(
        &source,
    )

    copied := lists.ArrayFromSlice<int>(
        allocator,
        deallocator,
        sourceSlice,
    )

    defer lists.DestroyArray<int>(
        &copied,
    )

    assert(len(copied) == 3)
    assert(copied[0] == 10)
    assert(copied[1] == 20)
    assert(copied[2] == 30)

    copied[0] = 999

    assert(copied[0] == 999)
    assert(source[0] == 10)
}

