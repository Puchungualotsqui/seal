TestCheckedAccess :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values := lists.DynamicArrayFilled<int>(
        allocator,
        deallocator,
        4,
        10,
    )

    defer lists.DestroyDynamicArray<int>(
        &values,
    )

    values[1] = 20
    values[2] = 30
    values[3] = 40

    first, foundFirst :=
        lists.DynamicArrayGet<int>(
            &values,
            0,
        )

    assert(foundFirst)
    assert(first == 10)

    last, foundLast :=
        lists.DynamicArrayGet<int>(
            &values,
            -1,
        )

    assert(foundLast)
    assert(last == 40)

    missingPositive, foundPositive :=
        lists.DynamicArrayGet<int>(
            &values,
            10,
        )

    assert(!foundPositive)
    assert(missingPositive == 0)

    missingNegative, foundNegative :=
        lists.DynamicArrayGet<int>(
            &values,
            -10,
        )

    assert(!foundNegative)
    assert(missingNegative == 0)

    overloaded, foundOverloaded :=
        lists.Get<int>(
            &values,
            2,
        )

    assert(foundOverloaded)
    assert(overloaded == 30)

    unsafeValue :=
        lists.DynamicArrayGetUnsafe<int>(
            &values,
            1,
        )

    assert(unsafeValue == 20)

    overloadedUnsafe :=
        lists.GetUnsafe<int>(
            &values,
            3,
        )

    assert(overloadedUnsafe == 40)

    changed := lists.DynamicArrayTrySet<int>(
        &values,
        1,
        25,
    )

    assert(changed)
    assert(values[1] == 25)

    changedNegative :=
        lists.TrySet<int>(
            &values,
            -1,
            45,
        )

    assert(changedNegative)
    assert(values[3] == 45)

    notChanged := lists.DynamicArrayTrySet<int>(
        &values,
        20,
        100,
    )

    assert(!notChanged)
    assert(len(values) == 4)

    lists.DynamicArraySetUnsafe<int>(
        &values,
        0,
        15,
    )

    assert(values[0] == 15)

    lists.SetUnsafe<int>(
        &values,
        2,
        35,
    )

    assert(values[2] == 35)
}

TestSliceCheckedAccess :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    array := lists.ArrayFilled<int>(
        allocator,
        deallocator,
        3,
        0,
    )

    defer lists.DestroyArray<int>(
        &array,
    )

    array[0] = 5
    array[1] = 10
    array[2] = 15

    slice := lists.ArraySlice<int>(
        &array,
    )

    value, found := lists.SliceGet<int>(
        &slice,
        -1,
    )

    assert(found)
    assert(value == 15)

    _, missing := lists.SliceGet<int>(
        &slice,
        3,
    )

    assert(!missing)

    changed := lists.SliceTrySet<int>(
        &slice,
        1,
        11,
    )

    assert(changed)
    assert(array[1] == 11)

    notChanged := lists.SliceTrySet<int>(
        &slice,
        4,
        100,
    )

    assert(!notChanged)

    unsafeValue := lists.SliceGetUnsafe<int>(
        &slice,
        0,
    )

    assert(unsafeValue == 5)

    lists.SliceSetUnsafe<int>(
        &slice,
        2,
        16,
    )

    assert(array[2] == 16)
}

TestArrayCheckedAccess :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values := lists.ArrayFilled<int>(
        allocator,
