TestDynamicArrayClear :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values :=
        lists.DynamicArrayWithCapacity<int>(
            allocator,
            deallocator,
            8,
        )

    defer lists.DestroyDynamicArray<int>(
        &values,
    )

    lists.Append<int>(&values, 1)
    lists.Append<int>(&values, 2)
    lists.Append<int>(&values, 3)

    originalCapacity :=
        lists.DynamicArrayCapacity<int>(
            &values,
        )

    lists.Clear<int>(
        &values,
    )

    assert(len(values) == 0)

    assert(
        lists.DynamicArrayCapacity<int>(
            &values,
        ) == originalCapacity,
    )

    lists.Append<int>(
        &values,
        100,
    )

    assert(len(values) == 1)
    assert(values[0] == 100)
}

