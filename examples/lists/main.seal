    assert(len(runtimeQueue) == 0)

    staticQueue :=
        lists.QueueWithStaticCapacity<int, 10>(
            allocator,
            deallocator,
        )

    defer lists.DestroyQueue<int>(
        &staticQueue,
    )

    assert(len(staticQueue) == 0)

    lists.Enqueue<int>(
        &staticQueue,
        55,
    )

    assert(
        lists.QueueFront<int>(
            &staticQueue,
        ) == 55,
    )
}

Point :: struct {
        X int
        Y int
    }

PointHash :: pure task(
    value Point,
) uint {
    /*
    Using only X deliberately permits collisions between points with
    the same X. The equality task still distinguishes the complete key.
    */
    return lists.HashInt(value.X)
}

PointEqual :: pure task(
    left Point,
    right Point,
) bool {
    return left.X == right.X &&
        left.Y == right.Y
}

TestStructElements :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values :=
        lists.NewDynamicArrayEmpty<Point>(
            allocator,
            deallocator,
        )

    defer lists.DestroyDynamicArray<Point>(
        &values,
    )

    lists.Append<Point>(
        &values,
        Point{
            X = 10,
            Y = 20,
        },
    )

    lists.Append<Point>(
        &values,
        Point{
            X = 30,
            Y = 40,
        },
    )

    assert(len(values) == 2)

    first := values[0]
    second := values[1]

    assert(first.X == 10)
    assert(first.Y == 20)

    assert(second.X == 30)
    assert(second.Y == 40)

    values[1] = Point{
        X = 50,
        Y = 60,
    }

    changed := values[1]

    assert(changed.X == 50)
    assert(changed.Y == 60)
}

