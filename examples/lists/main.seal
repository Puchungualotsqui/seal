TestStack :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    stack := lists.NewStack<int>(
        allocator,
        deallocator,
    )

    defer lists.DestroyStack<int>(
        &stack,
    )

    assert(len(stack) == 0)
    assert(lists.StackIsEmpty<int>(&stack))

    lists.Push<int>(&stack, 10)
    lists.Push<int>(&stack, 20)
    lists.Push<int>(&stack, 30)

    assert(len(stack) == 3)
    assert(!lists.StackIsEmpty<int>(&stack))
    assert(lists.Peek<int>(&stack) == 30)

    third, foundThird := lists.StackPop<int>(
        &stack,
    )

    assert(foundThird)
    assert(third == 30)
    assert(lists.Peek<int>(&stack) == 20)

    second, foundSecond := lists.StackPop<int>(
        &stack,
    )

    assert(foundSecond)
    assert(second == 20)

    first, foundFirst := lists.StackPop<int>(
        &stack,
    )

    assert(foundFirst)
    assert(first == 10)

    _, foundEmpty := lists.StackPop<int>(
        &stack,
    )

    assert(!foundEmpty)
    assert(lists.StackIsEmpty<int>(&stack))
}

TestStackCapacityConstructors :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    runtimeStack := lists.StackWithCapacity<int>(
        allocator,
        deallocator,
        10,
    )

    defer lists.DestroyStack<int>(
        &runtimeStack,
    )

    assert(len(runtimeStack) == 0)

    staticStack :=
        lists.StackWithStaticCapacity<int, 12>(
            allocator,
            deallocator,
        )

    defer lists.DestroyStack<int>(
        &staticStack,
    )

    assert(len(staticStack) == 0)

    lists.Push<int>(
        &staticStack,
        42,
    )

    assert(lists.Peek<int>(&staticStack) == 42)
}

TestDequeBasic :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    deque := lists.NewDeque<int>(
        allocator,
        deallocator,
    )

    defer lists.DestroyDeque<int>(
        &deque,
    )

    assert(len(deque) == 0)
    assert(lists.DequeIsEmpty<int>(&deque))

    lists.PushBack<int>(&deque, 20)
    lists.PushBack<int>(&deque, 30)
    lists.PushFront<int>(&deque, 10)

    assert(len(deque) == 3)
    assert(!lists.DequeIsEmpty<int>(&deque))

    assert(lists.Front<int>(&deque) == 10)
    assert(lists.Back<int>(&deque) == 30)

    assert(deque[0] == 10)
    assert(deque[1] == 20)
    assert(deque[2] == 30)
    assert(deque[-1] == 30)

    deque[1] = 25

    assert(deque[1] == 25)

    front, foundFront := lists.PopFront<int>(
        &deque,
    )

    assert(foundFront)
    assert(front == 10)

    back, foundBack := lists.PopBack<int>(
        &deque,
    )

    assert(foundBack)
    assert(back == 30)

    assert(len(deque) == 1)
    assert(lists.Front<int>(&deque) == 25)
    assert(lists.Back<int>(&deque) == 25)

    remaining, foundRemaining :=
        lists.PopFront<int>(
            &deque,
        )

    assert(foundRemaining)
    assert(remaining == 25)
    assert(len(deque) == 0)

    _, foundEmptyFront :=
        lists.PopFront<int>(
            &deque,
        )

    assert(!foundEmptyFront)

    _, foundEmptyBack :=
        lists.PopBack<int>(
            &deque,
        )

    assert(!foundEmptyBack)
}

TestDequeWrappingAndGrowth :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    deque := lists.DequeWithCapacity<int>(
        allocator,
        deallocator,
        4,
    )

    defer lists.DestroyDeque<int>(
        &deque,
    )

    lists.PushBack<int>(&deque, 1)
    lists.PushBack<int>(&deque, 2)
    lists.PushBack<int>(&deque, 3)
    lists.PushBack<int>(&deque, 4)

    first, foundFirst := lists.PopFront<int>(
        &deque,
    )

    assert(foundFirst)
    assert(first == 1)

    second, foundSecond := lists.PopFront<int>(
        &deque,
    )

    assert(foundSecond)
    assert(second == 2)

    lists.PushBack<int>(&deque, 5)
    lists.PushBack<int>(&deque, 6)

    assert(len(deque) == 4)

    assert(deque[0] == 3)
    assert(deque[1] == 4)
    assert(deque[2] == 5)
    assert(deque[3] == 6)

    /*
    This append forces growth while the logical contents wrap around
    the end of the original circular allocation.
    */
    lists.PushBack<int>(&deque, 7)

    assert(len(deque) == 5)

    assert(deque[0] == 3)
    assert(deque[1] == 4)
    assert(deque[2] == 5)
    assert(deque[3] == 6)
    assert(deque[4] == 7)

    lists.PushFront<int>(&deque, 2)

    assert(len(deque) == 6)
    assert(deque[0] == 2)
    assert(deque[1] == 3)
    assert(deque[-1] == 7)
}

TestDequeCapacityConstructors :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    runtimeDeque :=
        lists.DequeWithCapacity<int>(
            allocator,
            deallocator,
            10,
        )

    defer lists.DestroyDeque<int>(
        &runtimeDeque,
    )

    assert(len(runtimeDeque) == 0)

    assert(
        lists.DequeCapacity<int>(
            &runtimeDeque,
        ) == 10,
    )

    staticDeque :=
        lists.DequeWithStaticCapacity<int, 12>(
            allocator,
            deallocator,
        )

    defer lists.DestroyDeque<int>(
        &staticDeque,
    )

    assert(len(staticDeque) == 0)

    assert(
        lists.DequeCapacity<int>(
            &staticDeque,
        ) == 12,
    )
}

TestDequeClear :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    deque := lists.DequeWithCapacity<int>(
        allocator,
        deallocator,
        8,
    )

    defer lists.DestroyDeque<int>(
        &deque,
    )

    lists.PushBack<int>(&deque, 1)
    lists.PushBack<int>(&deque, 2)
    lists.PushFront<int>(&deque, 0)

    originalCapacity := lists.DequeCapacity<int>(
        &deque,
    )

    lists.ClearDeque<int>(
        &deque,
    )

    assert(len(deque) == 0)
    assert(lists.DequeIsEmpty<int>(&deque))

    assert(
        lists.DequeCapacity<int>(
            &deque,
        ) == originalCapacity,
    )

    lists.PushBack<int>(&deque, 100)

    assert(len(deque) == 1)
    assert(lists.Front<int>(&deque) == 100)
}

TestQueue :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    queue := lists.NewQueue<int>(
        allocator,
        deallocator,
    )

    defer lists.DestroyQueue<int>(
        &queue,
    )

    assert(len(queue) == 0)
    assert(lists.QueueIsEmpty<int>(&queue))

    lists.Enqueue<int>(&queue, 10)
    lists.Enqueue<int>(&queue, 20)
    lists.Enqueue<int>(&queue, 30)

    assert(len(queue) == 3)
    assert(!lists.QueueIsEmpty<int>(&queue))
    assert(lists.QueueFront<int>(&queue) == 10)

    first, foundFirst := lists.Dequeue<int>(
        &queue,
    )

    assert(foundFirst)
    assert(first == 10)

    second, foundSecond := lists.Dequeue<int>(
        &queue,
    )

    assert(foundSecond)
    assert(second == 20)

    third, foundThird := lists.Dequeue<int>(
        &queue,
    )

    assert(foundThird)
    assert(third == 30)

    _, foundEmpty := lists.Dequeue<int>(
        &queue,
    )

    assert(!foundEmpty)
    assert(lists.QueueIsEmpty<int>(&queue))
}

TestQueueCapacityConstructors :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    runtimeQueue :=
        lists.QueueWithCapacity<int>(
            allocator,
            deallocator,
            8,
        )

    defer lists.DestroyQueue<int>(
        &runtimeQueue,
    )

    assert(len(runtimeQueue) == 0)

    staticQueue :=
        lists.QueueWithStaticCapacity<int, 10>(
            allocator,
            deallocator,
        )

    defer lists.DestroyQueue<int>(
        &staticQueue,
    )

    assert(len(staticQueue) == 0)

    lists.Enqueue<int>(
        &staticQueue,
        55,
    )

    assert(
        lists.QueueFront<int>(
            &staticQueue,
        ) == 55,
    )
}

TestStructElements :: task() {
    Point :: struct {
        X int
        Y int
    }

    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values :=
        lists.NewDynamicArrayEmpty<Point>(
            allocator,
            deallocator,
        )

    defer lists.DestroyDynamicArray<Point>(
        &values,
    )

    lists.Append<Point>(
        &values,
        Point{
            X = 10,
            Y = 20,
        },
    )

    lists.Append<Point>(
        &values,
        Point{
            X = 30,
            Y = 40,
        },
    )

    assert(len(values) == 2)

    first := values[0]
    second := values[1]

    assert(first.X == 10)
    assert(first.Y == 20)

    assert(second.X == 30)
    assert(second.Y == 40)

    values[1] = Point{
        X = 50,
        Y = 60,
    }

    changed := values[1]

    assert(changed.X == 50)
    assert(changed.Y == 60)
}

TestDestroyTwice :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values :=
        lists.NewDynamicArrayEmpty<int>(
            allocator,
            deallocator,
        )

    lists.Append<int>(
        &values,
        10,
    )

    lists.DestroyDynamicArray<int>(
        &values,
    )

    assert(len(values) == 0)

    assert(
        lists.DynamicArrayCapacity<int>(
            &values,
        ) == 0,
    )

    lists.DestroyDynamicArray<int>(
        &values,
    )

    assert(len(values) == 0)

    array := lists.ArrayFilled<int>(
        allocator,
        deallocator,
        3,
        5,
    )

    lists.DestroyArray<int>(
        &array,
    )

    assert(len(array) == 0)

    lists.DestroyArray<int>(
        &array,
    )

    assert(len(array) == 0)

    deque := lists.NewDeque<int>(
        allocator,
        deallocator,
    )

    lists.PushBack<int>(
        &deque,
        1,
    )

    lists.DestroyDeque<int>(
        &deque,
    )

    assert(len(deque) == 0)

    lists.DestroyDeque<int>(
        &deque,
    )

    assert(len(deque) == 0)
}

