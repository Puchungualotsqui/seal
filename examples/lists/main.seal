}

TestHashMapCustomKeyAndCollisions :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    points :=
        lists.NewHashMapEmpty<
            Point,
            string,
            PointHash,
            PointEqual
        >(
            allocator,
            deallocator,
        )

    defer lists.DestroyHashMap<
        Point,
        string,
        PointHash,
        PointEqual
    >(
        &points,
    )

    first := Point{
        X = 10,
        Y = 20,
    }

    collision := Point{
        X = 10,
        Y = 30,
    }

    other := Point{
        X = 40,
        Y = 50,
    }

    lists.HashMapPut<
        Point,
        string,
        PointHash,
        PointEqual
    >(
        &points,
        first,
        "first",
    )

    lists.HashMapPut<
        Point,
        string,
        PointHash,
        PointEqual
    >(
        &points,
        collision,
        "collision",
    )

    lists.HashMapPut<
        Point,
        string,
        PointHash,
        PointEqual
    >(
        &points,
        other,
        "other",
    )

    assert(
        lists.HashMapAt<
            Point,
            string,
            PointHash,
            PointEqual
        >(
            &points,
            first,
        ) == "first",
    )

    assert(
        lists.HashMapAt<
            Point,
            string,
            PointHash,
            PointEqual
        >(
            &points,
            collision,
        ) == "collision",
    )

    assert(
        lists.HashMapAt<
            Point,
            string,
            PointHash,
            PointEqual
        >(
            &points,
            other,
        ) == "other",
    )

    assert(
        lists.HashMapLength<
            Point,
            string,
            PointHash,
            PointEqual
        >(
            &points,
        ) == 3,
    )
}

TestHashSetBasic :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    names :=
        lists.NewHashSetEmpty<
            string,
            lists.HashString,
            lists.EqualString
        >(
            allocator,
            deallocator,
        )

    defer lists.DestroyHashSet<
        string,
        lists.HashString,
        lists.EqualString
    >(
        &names,
    )

    assert(
        lists.HashSetIsEmpty<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
        ),
    )

    insertedAda :=
        lists.HashSetAdd<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
            "Ada",
        )

    assert(insertedAda)

    insertedGrace :=
        lists.HashSetAdd<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
            "Grace",
        )

    assert(insertedGrace)

    insertedDuplicate :=
        lists.HashSetAdd<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
            "Ada",
        )

    assert(!insertedDuplicate)

    assert(
        lists.HashSetLength<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
        ) == 2,
    )

    assert(
        lists.HashSetContains<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
            "Ada",
        ),
    )

    assert(
        !lists.HashSetContains<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
            "Linus",
        ),
    )

    removedAda :=
        lists.HashSetRemove<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
            "Ada",
        )

    assert(removedAda)

    removedAgain :=
        lists.HashSetRemove<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
            "Ada",
        )

    assert(!removedAgain)

    assert(
        !lists.HashSetContains<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
            "Ada",
        ),
    )

    lists.ReserveHashSet<
        string,
        lists.HashString,
        lists.EqualString
    >(
        &names,
        100,
    )

    assert(
        lists.HashSetCapacity<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
        ) >= 100,
    )

    lists.ShrinkHashSetToFit<
        string,
        lists.HashString,
        lists.EqualString
    >(
        &names,
    )

    assert(
        lists.HashSetContains<
            string,
            lists.HashString,
            lists.EqualString
        >(
            &names,
            "Grace",
        ),
    )
}

TestHashSetValuesAndClear :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    values :=
        lists.HashSetWithStaticCapacity<
            int,
            lists.HashInt,
            lists.EqualInt,
            8
        >(
            allocator,
            deallocator,
        )

    defer lists.DestroyHashSet<
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &values,
    )

    lists.HashSetAdd<
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &values,
        10,
    )

    lists.HashSetAdd<
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &values,
        20,
    )

    lists.HashSetAdd<
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &values,
        30,
    )

    setValues :=
        lists.HashSetValues<
            int,
            lists.HashInt,
            lists.EqualInt
        >(
            &values,
        )

    defer lists.DestroyDynamicArray<int>(
        &setValues,
    )

    assert(len(setValues) == 3)

    foundTen := false
    foundTwenty := false
    foundThirty := false

    index: int = 0

    for index < cast<int>(len(setValues)) {
        value := setValues[index]

        if value == 10 {
            foundTen = true
        }

        if value == 20 {
            foundTwenty = true
        }

        if value == 30 {
            foundThirty = true
        }

        index += 1
    }

    assert(foundTen)
    assert(foundTwenty)
    assert(foundThirty)

    lists.ClearHashSet<
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &values,
    )

    assert(
        lists.HashSetLength<
            int,
            lists.HashInt,
            lists.EqualInt
        >(
            &values,
        ) == 0,
    )

    assert(
        lists.HashSetIsEmpty<
            int,
            lists.HashInt,
            lists.EqualInt
        >(
            &values,
        ),
    )
}

TestHashCollectionsDestroyTwice :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    map :=
        lists.NewHashMapEmpty<
            int,
            int,
            lists.HashInt,
            lists.EqualInt
        >(
            allocator,
            deallocator,
        )

    lists.HashMapPut<
        int,
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &map,
        1,
        10,
    )

    lists.DestroyHashMap<
        int,
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &map,
    )

    assert(
        lists.HashMapLength<
            int,
            int,
            lists.HashInt,
            lists.EqualInt
        >(
            &map,
        ) == 0,
    )

    lists.DestroyHashMap<
        int,
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &map,
    )

    set :=
        lists.NewHashSetEmpty<
            int,
            lists.HashInt,
            lists.EqualInt
        >(
            allocator,
            deallocator,
        )

    lists.HashSetAdd<
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &set,
        1,
    )

    lists.DestroyHashSet<
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &set,
    )

    assert(
        lists.HashSetLength<
            int,
            lists.HashInt,
            lists.EqualInt
        >(
            &set,
        ) == 0,
    )

    lists.DestroyHashSet<
        int,
        lists.HashInt,
        lists.EqualInt
    >(
        &set,
    )
}

