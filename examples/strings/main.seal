TestPrimitiveTextRules :: task() {
    ascii := "hello"
    unicode := "mañana"
    letter := "ñ"

    assert(size(ascii) == 5)
    assert(len(ascii) == 5)

    assert(size(unicode) == 7)
    assert(len(unicode) == 6)

    assert(size(letter) == 2)
    assert(len(letter) == 1)

    assert(unicode[0] == 'm')
    assert(unicode[2] == 'ñ')
    assert(unicode[-1] == 'a')

    cText := c"mañana"

    assert(size(cText) == 7)
    assert(len(cText) == 6)
    assert(cText[2] == 'ñ')
    assert(cText[-1] == 'a')
}

TestBorrowedStringView :: task() {
    source := c"hello"

    view := strings.BorrowString(source)

    assert(view == "hello")
    assert(size(view) == 5)
    assert(len(view) == 5)
}

TestClone :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    source := "mañana"

    owned := strings.Clone(
        allocator,
        source,
    )

    if owned.Data == nil {
        panic("Clone allocation failed")
    }

    defer strings.Destroy(
        deallocator,
        &owned,
    )

    view := strings.View(&owned)

    assert(view == source)
    assert(size(view) == 7)
    assert(len(view) == 6)

    sourceData := cast<rawptr>(source)
    ownedData := owned.Data

    assert(sourceData != ownedData)
}

TestCStringClone :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    source := c"Seal"

    owned := strings.CloneC(
        allocator,
        source,
    )

    if owned.Data == nil {
        panic("CloneC allocation failed")
    }

    defer strings.DestroyC(
        deallocator,
        &owned,
    )

    view := strings.CView(&owned)

    assert(view == source)
    assert(size(view) == 4)
    assert(len(view) == 4)

    assert(
        owned.Data[
            cast<int>(owned.ByteLength)
        ] == 0,
    )
}

TestStringToCString :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    source := "mañana"

    owned := strings.ToCString(
        allocator,
        source,
    )

    defer strings.DestroyC(
        deallocator,
        &owned,
    )

    cView := strings.CView(&owned)

    assert(cView == c"mañana")
    assert(size(cView) == size(source))
    assert(len(cView) == len(source))

    assert(
        owned.Data[
            cast<int>(owned.ByteLength)
        ] == 0,
    )
}

TestEmbeddedNullRejection :: task(
    allocator mem.Allocator,
) {
    source := "left\0right"

    assert(strings.HasNullByte(source))

    owned, success := strings.TryToCString(
        allocator,
        source,
    )

    assert(!success)
    assert(owned.Data == nil)
}

TestCStringToOwnedString :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    source := c"world"

    owned := strings.FromCString(
        allocator,
        source,
    )

    if owned.Data == nil {
        panic("FromCString allocation failed")
    }

    defer strings.Destroy(
        deallocator,
        &owned,
    )

    view := strings.View(&owned)

    assert(view == "world")
    assert(size(view) == 5)
    assert(len(view) == 5)
}

TestConcat :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    owned := strings.Concat(
        allocator,
        "hello, ",
        "世界",
    )

    if owned.Data == nil {
        panic("Concat allocation failed")
    }

    defer strings.Destroy(
        deallocator,
        &owned,
    )

    result := strings.View(&owned)

    assert(result == "hello, 世界")
    assert(size(result) == 13)
    assert(len(result) == 9)
    assert(result[-1] == '界')
}

TestConcat3 :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    owned := strings.Concat3(
        allocator,
        "Seal",
        " ",
        "language",
    )

    if owned.Data == nil {
        panic("Concat3 allocation failed")
    }

    defer strings.Destroy(
        deallocator,
        &owned,
    )

    result := strings.View(&owned)

    assert(result == "Seal language")
}

TestPredicates :: task() {
    value := "Seal programming language"

    assert(!strings.IsEmpty(value))
    assert(strings.IsEmpty(""))

    assert(
        strings.StartsWith(
            value,
            "Seal",
        ),
    )

    assert(
        !strings.StartsWith(
            value,
            "seal",
        ),
    )

    assert(
        strings.StartsWith(
            value,
            "",
        ),
    )

    assert(
        strings.EndsWith(
            value,
            "language",
        ),
    )

    assert(
        strings.EndsWith(
            value,
            "",
        ),
    )

    assert(
        strings.Contains(
            value,
            "programming",
        ),
    )

    assert(
        strings.Contains(
            "mañana",
            "ñ",
        ),
    )

    assert(
        strings.Contains(
            value,
            "",
        ),
    )

    assert(
        !strings.Contains(
            value,
            "compiler",
        ),
    )
}

TestEmptyValues :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    cloned := strings.Clone(
        allocator,
        "",
    )

    if cloned.Data == nil {
        panic("empty Clone allocation failed")
    }

    defer strings.Destroy(
        deallocator,
        &cloned,
    )

    assert(strings.View(&cloned) == "")
    assert(cloned.ByteLength == 0)

    cOwned := strings.ToCString(
        allocator,
        "",
    )

    defer strings.DestroyC(
        deallocator,
        &cOwned,
    )

    assert(strings.CView(&cOwned) == c"")
    assert(cOwned.ByteLength == 0)
    assert(cOwned.Data[0] == 0)
}

TestByteOffsets :: task() {
    value := "Añ😀Z"

    /*
    A  = 1 byte
    ñ  = 2 bytes
    😀 = 4 bytes
    Z  = 1 byte
    */
    assert(size(value) == 8)
    assert(len(value) == 4)

    assert(
        strings.ByteOffset(
            value,
            0,
        ) == 0,
    )

    assert(
        strings.ByteOffset(
            value,
            1,
        ) == 1,
    )

    assert(
        strings.ByteOffset(
            value,
            2,
        ) == 3,
    )

    assert(
        strings.ByteOffset(
            value,
            3,
        ) == 7,
    )

    assert(
        strings.ByteOffset(
            value,
            4,
        ) == 8,
    )

    assert(
        strings.ByteOffset(
            value,
            -1,
        ) == 7,
    )

    assert(
        strings.ByteOffset(
            value,
            -2,
        ) == 3,
    )

    assert(
        strings.ByteOffset(
            value,
            -4,
        ) == 0,
    )
}

TestBorrowSlice :: task() {
    value := "Año 😀 Seal"

    assert(
        strings.BorrowSlice(
            value,
            0,
            3,
        ) == "Año",
    )

    assert(
        strings.BorrowSlice(
            value,
            4,
            5,
        ) == "😀",
    )

    assert(
        strings.BorrowSlice(
            value,
            -4,
            cast<int>(len(value)),
        ) == "Seal",
    )

    assert(
        strings.BorrowSlice(
            value,
            2,
            2,
        ) == "",
    )

    assert(
        strings.BorrowSlice(
            value,
            0,
            cast<int>(len(value)),
        ) == value,
    )

    assert(
        strings.BorrowSlice(
            value,
            -1,
            cast<int>(len(value)),
        ) == "l",
    )
}

TestCloneSlice :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    source := "zero mañana final"

    owned := strings.CloneSlice(
        allocator,
        source,
        5,
        11,
    )

    if owned.Data == nil {
        panic("CloneSlice allocation failed")
    }

    defer strings.Destroy(
        deallocator,
        &owned,
    )

    result := strings.View(&owned)

    assert(result == "mañana")
    assert(size(result) == 7)
    assert(len(result) == 6)

    sourceData := cast<rawptr>(source)

    assert(owned.Data != sourceData)
}

TestSearch :: task() {
    value := "añ😀ñ seal ñ"

    first, foundFirst := strings.IndexOf(
        value,
        "ñ",
    )

    assert(foundFirst)
    assert(first == 1)

    emoji, foundEmoji := strings.IndexOf(
        value,
        "😀",
    )

    assert(foundEmoji)
    assert(emoji == 2)

    word, foundWord := strings.IndexOf(
        value,
        "seal",
    )

    assert(foundWord)
    assert(word == 5)

    last, foundLast := strings.LastIndexOf(
        value,
        "ñ",
    )

    assert(foundLast)
    assert(last == 10)

    emptyFirst, foundEmptyFirst := strings.IndexOf(
        value,
        "",
    )

    assert(foundEmptyFirst)
    assert(emptyFirst == 0)

    emptyLast, foundEmptyLast := strings.LastIndexOf(
        value,
        "",
    )

    assert(foundEmptyLast)
    assert(emptyLast == cast<int>(len(value)))

    _, missing := strings.IndexOf(
        value,
        "compiler",
    )

    assert(!missing)

    _, missingLast := strings.LastIndexOf(
        value,
        "compiler",
    )

    assert(!missingLast)

    assert(
        strings.Count(
            "aaaa",
            "aa",
        ) == 2,
    )

    assert(
        strings.Count(
            "mañana mañana",
            "mañana",
        ) == 2,
    )

    assert(
        strings.Count(
            value,
            "ñ",
        ) == 3,
    )

    assert(
        strings.Count(
            value,
            "",
        ) == 0,
    )
}

TestRepeat :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    owned := strings.Repeat(
        allocator,
        "ñ😀",
        3,
    )

    if owned.Data == nil {
        panic("Repeat allocation failed")
    }

    defer strings.Destroy(
        deallocator,
        &owned,
    )

    result := strings.View(&owned)

    assert(result == "ñ😀ñ😀ñ😀")
    assert(len(result) == 6)
    assert(size(result) == 18)
}

TestRepeatEmpty :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    zeroCount := strings.Repeat(
        allocator,
        "Seal",
        0,
    )

    if zeroCount.Data == nil {
        panic("zero-count Repeat allocation failed")
    }

    defer strings.Destroy(
        deallocator,
        &zeroCount,
    )

    assert(strings.View(&zeroCount) == "")
    assert(zeroCount.ByteLength == 0)

    emptyValue := strings.Repeat(
        allocator,
        "",
        10,
    )

    if emptyValue.Data == nil {
        panic("empty-value Repeat allocation failed")
    }

    defer strings.Destroy(
        deallocator,
        &emptyValue,
    )

    assert(strings.View(&emptyValue) == "")
    assert(emptyValue.ByteLength == 0)
}

TestSplit :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    parts := strings.Split(
        allocator,
        deallocator,
        "one,two,,four",
        ",",
    )

    defer lists.DestroyDynamicArray<string>(
        &parts,
    )

    assert(len(parts) == 4)

    assert(parts[0] == "one")
    assert(parts[1] == "two")
    assert(parts[2] == "")
    assert(parts[3] == "four")

    edgeParts := strings.Split(
        allocator,
        deallocator,
        ",a,",
        ",",
    )

    defer lists.DestroyDynamicArray<string>(
        &edgeParts,
    )

    assert(len(edgeParts) == 3)

    assert(edgeParts[0] == "")
    assert(edgeParts[1] == "a")
    assert(edgeParts[2] == "")

    noMatch := strings.Split(
        allocator,
        deallocator,
        "Seal",
        ",",
    )

    defer lists.DestroyDynamicArray<string>(
        &noMatch,
    )

    assert(len(noMatch) == 1)
    assert(noMatch[0] == "Seal")

    repeatedSeparator := strings.Split(
        allocator,
        deallocator,
        "a----b",
        "--",
    )

    defer lists.DestroyDynamicArray<string>(
        &repeatedSeparator,
    )

    assert(len(repeatedSeparator) == 3)

    assert(repeatedSeparator[0] == "a")
    assert(repeatedSeparator[1] == "")
    assert(repeatedSeparator[2] == "b")

    unicode := strings.Split(
        allocator,
        deallocator,
        "mañana ñ mundo ñ final",
        " ñ ",
    )

    defer lists.DestroyDynamicArray<string>(
        &unicode,
    )

    assert(len(unicode) == 3)

    assert(unicode[0] == "mañana")
    assert(unicode[1] == "mundo")
    assert(unicode[2] == "final")
}

