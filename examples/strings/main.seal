TestReplaceAllEdgeCases :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    noMatch := strings.ReplaceAll(
        allocator,
        "Seal language",
        "compiler",
        "runtime",
    )

    defer strings.Destroy(
        deallocator,
        &noMatch,
    )

    assert(
        strings.View(&noMatch) ==
            "Seal language",
    )

    emptyNeedle := strings.ReplaceAll(
        allocator,
        "Seal",
        "",
        "x",
    )

    defer strings.Destroy(
        deallocator,
        &emptyNeedle,
    )

    assert(
        strings.View(&emptyNeedle) ==
            "Seal",
    )

    emptyValue := strings.ReplaceAll(
        allocator,
        "",
        "a",
        "b",
    )

    defer strings.Destroy(
        deallocator,
        &emptyValue,
    )

    assert(strings.View(&emptyValue) == "")

    completeRemoval := strings.ReplaceAll(
        allocator,
        "aaaa",
        "a",
        "",
    )

    defer strings.Destroy(
        deallocator,
        &completeRemoval,
    )

    assert(
        strings.View(&completeRemoval) ==
            "",
    )

    completeReplacement := strings.ReplaceAll(
        allocator,
        "Seal",
        "Seal",
        "language",
    )

    defer strings.Destroy(
        deallocator,
        &completeReplacement,
    )

    assert(
        strings.View(
            &completeReplacement,
        ) == "language",
    )
}

TestDestroyTwice :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    owned := strings.Clone(
        allocator,
        "temporary",
    )

    if owned.Data == nil {
        panic("Destroy test allocation failed")
    }

    strings.Destroy(
        deallocator,
        &owned,
    )

    assert(owned.Data == nil)
    assert(owned.ByteLength == 0)

    strings.Destroy(
        deallocator,
        &owned,
    )

    assert(owned.Data == nil)
    assert(owned.ByteLength == 0)

    cOwned := strings.ToCString(
        allocator,
        "temporary",
    )

    strings.DestroyC(
        deallocator,
        &cOwned,
    )

    assert(cOwned.Data == nil)
    assert(cOwned.ByteLength == 0)

    strings.DestroyC(
        deallocator,
        &cOwned,
    )

    assert(cOwned.Data == nil)
    assert(cOwned.ByteLength == 0)
}

Main :: task() {
    cAllocator := mem.NewCAllocator()

    allocator := cast<mem.Allocator>(
        &cAllocator,
    )

    deallocator := cast<mem.Deallocator>(
        &cAllocator,
    )

    TestPrimitiveTextRules()
    TestBorrowedStringView()

    TestClone(
        allocator,
        deallocator,
    )

    TestCStringClone(
        allocator,
        deallocator,
    )

    TestStringToCString(
        allocator,
        deallocator,
    )

    TestEmbeddedNullRejection(
        allocator,
    )

    TestCStringToOwnedString(
        allocator,
        deallocator,
    )

