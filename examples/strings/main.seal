    )

    assert(len(emptyFields) == 3)

    assert(emptyFields[0] == "")
    assert(emptyFields[1] == "")
    assert(emptyFields[2] == "")
}

TestSplitUnicodeScalars :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    scalars := strings.Split(
        allocator,
        deallocator,
        "Añ😀界",
        "",
    )

    defer lists.DestroyDynamicArray<string>(
        &scalars,
    )

    assert(len(scalars) == 4)

    assert(scalars[0] == "A")
    assert(scalars[1] == "ñ")
    assert(scalars[2] == "😀")
    assert(scalars[3] == "界")

    assert(size(scalars[0]) == 1)
    assert(size(scalars[1]) == 2)
    assert(size(scalars[2]) == 4)
    assert(size(scalars[3]) == 3)

    assert(len(scalars[0]) == 1)
    assert(len(scalars[1]) == 1)
    assert(len(scalars[2]) == 1)
    assert(len(scalars[3]) == 1)
}

TestJoin :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    parts := strings.Split(
        allocator,
        deallocator,
        "one,two,three",
        ",",
    )

    defer lists.DestroyDynamicArray<string>(
        &parts,
    )

    partsSlice :=
        lists.DynamicArraySlice<string>(
            &parts,
        )

    joined := strings.Join(
        allocator,
        partsSlice,
        " | ",
    )

    defer strings.Destroy(
        deallocator,
        &joined,
    )

    assert(
        strings.View(&joined) ==
            "one | two | three",
    )

    assert(
        joined.ByteLength ==
            size("one | two | three"),
    )

    unicodeParts := strings.Split(
        allocator,
        deallocator,
        "mañana,😀,世界",
        ",",
    )

    defer lists.DestroyDynamicArray<string>(
        &unicodeParts,
    )

    unicodeSlice :=
        lists.DynamicArraySlice<string>(
            &unicodeParts,
        )

    unicodeJoined := strings.Join(
        allocator,
        unicodeSlice,
        "—",
    )

    defer strings.Destroy(
        deallocator,
        &unicodeJoined,
    )

    assert(
        strings.View(&unicodeJoined) ==
            "mañana—😀—世界",
    )
}

TestJoinEdgeCases :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    emptyParts :=
        lists.NewDynamicArrayEmpty<string>(
            allocator,
            deallocator,
        )

    defer lists.DestroyDynamicArray<string>(
        &emptyParts,
    )

    emptySlice :=
        lists.DynamicArraySlice<string>(
            &emptyParts,
        )

    emptyJoined := strings.Join(
        allocator,
        emptySlice,
        ",",
    )

    defer strings.Destroy(
        deallocator,
        &emptyJoined,
    )

    assert(strings.View(&emptyJoined) == "")
    assert(emptyJoined.ByteLength == 0)

    onePart :=
        lists.NewDynamicArrayEmpty<string>(
            allocator,
            deallocator,
        )

    defer lists.DestroyDynamicArray<string>(
        &onePart,
    )

    lists.Append<string>(
        &onePart,
        "Seal",
    )

    oneSlice :=
        lists.DynamicArraySlice<string>(
            &onePart,
        )

    oneJoined := strings.Join(
        allocator,
        oneSlice,
        "ignored",
    )

    defer strings.Destroy(
        deallocator,
        &oneJoined,
    )

    assert(
        strings.View(&oneJoined) ==
            "Seal",
    )

    emptySeparatorParts := strings.Split(
        allocator,
        deallocator,
        "a,b,c",
        ",",
    )

    defer lists.DestroyDynamicArray<string>(
        &emptySeparatorParts,
    )

    emptySeparatorSlice :=
        lists.DynamicArraySlice<string>(
            &emptySeparatorParts,
        )

    joinedWithoutSeparator := strings.Join(
        allocator,
        emptySeparatorSlice,
        "",
    )

    defer strings.Destroy(
        deallocator,
        &joinedWithoutSeparator,
    )

    assert(
        strings.View(
            &joinedWithoutSeparator,
        ) == "abc",
    )
}

TestSplitJoinRoundTrip :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    source := "mañana|😀|Seal|世界"

    parts := strings.Split(
        allocator,
        deallocator,
        source,
        "|",
    )

    defer lists.DestroyDynamicArray<string>(
        &parts,
    )

    partsSlice :=
        lists.DynamicArraySlice<string>(
            &parts,
        )

    joined := strings.Join(
        allocator,
        partsSlice,
        "|",
    )

    defer strings.Destroy(
        deallocator,
        &joined,
    )

    assert(strings.View(&joined) == source)
}

TestReplaceAll :: task(
    allocator mem.Allocator,
    deallocator mem.Deallocator,
) {
    replaced := strings.ReplaceAll(
        allocator,
        "abcabc",
        "ab",
        "XY",
    )

    defer strings.Destroy(
        deallocator,
        &replaced,
    )

    assert(
        strings.View(&replaced) ==
            "XYcXYc",
    )

    compacted := strings.ReplaceAll(
        allocator,
        "aaaa",
        "aa",
        "b",
    )

    defer strings.Destroy(
        deallocator,
        &compacted,
    )

    assert(
        strings.View(&compacted) ==
            "bb",
    )

    expanded := strings.ReplaceAll(
        allocator,
        "aaa",
        "a",
        "Seal",
    )

    defer strings.Destroy(
        deallocator,
        &expanded,
    )

    assert(
        strings.View(&expanded) ==
            "SealSealSeal",
    )

    removed := strings.ReplaceAll(
        allocator,
        "one---two---three",
        "---",
        "",
    )

    defer strings.Destroy(
        deallocator,
        &removed,
    )

    assert(
        strings.View(&removed) ==
            "onetwothree",
    )
}

