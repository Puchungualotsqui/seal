    a: i8 = 1
    b: i16 = 2
    c: i32 = 3
    d: i64 = 4

    e: u8 = 1
    f: u16 = 2
    g: u32 = 3
    h: u64 = 4

    i: int = 5
    j: uint = 6

    x: f32 = 1.5
    y: f64 = 2.5

    flag: bool = true
    ch: char = 'A'
    s: string = "hello"
    cs: cstring = c"world"

    p: rawptr = nil
